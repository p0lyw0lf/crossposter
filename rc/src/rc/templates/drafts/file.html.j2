{#
// part of the post itself
title: string;
description: string;
tags: string[];
// part of how we display the page for interaction
errors: string[];
messages: string[];
username: string | undefined;
#}

{% extends "base.html.j2" %}
{% block slot %}
<header>
  <h2><a href="./">../</a></h2>
</header>
<main>
  <div class="info">
    <h1>{{ title }}</h1>
  </div>
  <article class="preview">
    {{ description }}
    {% if errors %}
    <hr>
    {% endif %}
    {% for error in errors %}
    <div class="message error">{{ error }}</div>
    {% endfor %}
    {% if messages %}
    <hr>
    {% endif %}
    {% for message in messages %}
    <div class="message">{{ message }}</div>
    {% endfor %}
    <hr>
    <h2><a href="?">See Full Post</a></h2>
    {% if username %}
    <hr>
    <br><br><br><br>
    <form method="POST">
      <label for="submit">Very Dangerous!!</label>
      &nbsp;
      <button id="submit" type="submit">
        Put Thoughts Online
      </button>
    </form>
    <br><br><br><br>
    {% endif %}
  </article>
  <div class="tags">
    {% for tag in tags %}
    <span>#{{ tag }}</span>
    {% endfor %}
  </div>
</main>
{% endblock %}
